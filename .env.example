# ── Database (set ONE of these in Heroku config vars) ──────────────────────
# Option 1: MongoDB Atlas
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/cybersecpro

# Option 2: PostgreSQL (Heroku Postgres add-on sets this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Required ────────────────────────────────────────────────────────────────
JWT_SECRET=your-very-long-random-secret-at-least-32-chars

# ── Optional ─────────────────────────────────────────────────────────────────
NODE_ENV=production

# Auto-create admin on first boot
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=StrongPassword123!

# CORS — leave empty in production (same-origin requests don't need it)
# ALLOWED_ORIGINS=https://yourapp.herokuapp.com
